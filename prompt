// DB degine
/////////////////////////////////////////////////////
// GYM MANAGEMENT SYSTEM (LOGIN + REGISTRATION ONLY)
/////////////////////////////////////////////////////

Table organizations {
  id uuid [pk]
  org_code varchar [unique] // Example: GYMB-A9F3
  username varchar [unique] // Same as org_code
  name varchar
  owner_email varchar [unique]
  phone varchar
  password_hash varchar
  created_at timestamp
}

Table branches {
  id uuid [pk]
  org_id uuid [ref: > organizations.id]
  branch_code varchar [unique] // Example: GYMB-A9F3-BR01
  username varchar [unique]
  name varchar
  admin_email varchar
  password_hash varchar
  created_at timestamp
}


Table admins {
  id uuid [pk]
  org_id uuid [ref: > organizations.id]
  branch_id uuid [ref: > branches.id]
  admin_code varchar [unique] // ORG-ADM###
  username varchar [unique]
  email varchar
  phone varchar
  password_hash varchar
  created_at timestamp
}

Table trainers {
  id uuid [pk]
  org_id uuid [ref: > organizations.id]
  branch_id uuid [ref: > branches.id]
  trainer_code varchar [unique] // ORG-TRN###
  username varchar [unique]
  name varchar
  email varchar
  phone varchar
  password_hash varchar
  salary numeric
  start_date date
  shift_timings varchar
  is_personal_trainer boolean
  created_at timestamp
}

Table staff {
  id uuid [pk]
  org_id uuid [ref: > organizations.id]
  branch_id uuid [ref: > branches.id]
  staff_code varchar [unique] // ORG-STF###
  username varchar [unique]
  name varchar
  email varchar
  phone varchar
  password_hash varchar
  role varchar // cleaner, reception, etc.
  salary numeric
  start_date date
  shift_timings varchar
  created_at timestamp
}

Table users {
  id uuid [pk]
  org_id uuid [ref: > organizations.id]
  branch_id uuid [ref: > branches.id]
  user_code varchar [unique] // ORG-USR####
  username varchar [unique]
  name varchar
  email varchar
  phone varchar
  password_hash varchar
  start_date date
  plan varchar
  trainer_id uuid [ref: > trainers.id]
  created_at timestamp
}

Table premium_users {
  id uuid [pk]
  org_id uuid [ref: > organizations.id]
  branch_id uuid [ref: > branches.id]
  premium_code varchar [unique] // ORG-PRM####
  username varchar [unique]
  name varchar
  email varchar
  phone varchar
  password_hash varchar
  start_date date
  plan varchar
  trainer_id uuid [ref: > trainers.id]
  created_at timestamp
}

/////////////////////////////////////////////////////
// OTP TABLE (For email / phone verification)
/////////////////////////////////////////////////////

Table otps {
  id uuid [pk]
  
  org_id uuid [ref: > organizations.id, note: 'Optional']
  branch_id uuid [ref: > branches.id, note: 'Optional']

  email varchar
  phone varchar

  otp_code varchar // 4–8 digit OTP
  
  otp_type varchar // register_org, add_branch, login, forgot_password
  
  start_time timestamp // Time OTP was created
  end_time timestamp   // start_time + 60 seconds (handled by backend)

  is_used boolean      // true/false
  attempts int         // count attempts

  created_at timestamp
}

